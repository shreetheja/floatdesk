{
  "name": "@floatdesk/react",
  "version": "3.0.0",
  "description": "Drop-in React support widget — floating bug-report button with screenshot capture, screen recording, and live chat thread view",
  "type": "module",
  "license": "MIT",
  "author": "Shreetheja Nagasri <snshagri@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/shreetheja/floatdesk.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/shreetheja/floatdesk#readme",
  "bugs": {
    "url": "https://github.com/shreetheja/floatdesk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "support",
    "helpdesk",
    "widget",
    "react",
    "bug-report",
    "screenshot",
    "feedback"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external react",
    "dev": "tsup src/index.ts --format esm --dts --watch --external react",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "framer-motion": "^12.12.1",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.476.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
