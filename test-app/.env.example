# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real credentials.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3003

# ── Storage ─────────────────────────────────────────────────────────────────
# Leave blank to use in-memory storage (data resets on every restart).
# Set to a Postgres connection string to persist tickets across restarts.
DATABASE_URL=postgresql://user:pass@localhost:5432/floatdesk

# ── Slack ────────────────────────────────────────────────────────────────────
# Set SLACK_BOT_TOKEN + SLACK_CHANNEL_ID to post new tickets to a Slack channel.
# Required bot scopes: chat:write, users:read
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0123456789

# Set SLACK_SIGNING_SECRET to enable agent reply sync via the Slack Events API.
# Leave blank if you only want outbound ticket posting (no reply sync).
# Setup: Slack app → Event Subscriptions → request URL: https://yourhost/api/webhook/slack
#        Subscribe to: message.channels
SLACK_SIGNING_SECRET=

# ── Media: Google Cloud Storage ──────────────────────────────────────────────
# Set GCS_BUCKET + GCS_PROJECT_ID to enable screenshot/recording uploads via GCS.
# GCS takes priority over S3 when both are set.
GCS_PROJECT_ID=my-gcp-project
GCS_BUCKET=my-floatdesk-bucket

# Service account credentials (leave blank to use Application Default Credentials).
# Get these from GCP Console → IAM → Service Accounts → your account → Keys → Add Key → JSON.
# Copy client_email and private_key from the downloaded JSON file.
# IMPORTANT: replace actual newlines in private_key with \n so it fits on one line.
GCS_CLIENT_EMAIL=floatdesk@my-gcp-project.iam.gserviceaccount.com
GCS_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMII...\n-----END RSA PRIVATE KEY-----

# Optional: CDN / custom domain in front of the bucket (omit to use storage.googleapis.com)
GCS_PUBLIC_BASE_URL=

# ── Media: AWS S3 (alternative to GCS) ───────────────────────────────────────
AWS_REGION=us-east-1
AWS_S3_BUCKET=my-floatdesk-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_PUBLIC_BASE_URL=

# ── Feedback Call Booking ─────────────────────────────────────────────────────
# Set MEETING_URL to enable the "Book a Feedback Call" button in the widget.
# Use a Calendly, Cal.com, or any booking page URL.
# When a user books a call, Slack is notified with Award/Dismiss buttons.
# Clicking "Award Credits" in Slack rewards the user with CALL_CREDIT_REWARD credits.
MEETING_URL=https://calendly.com/snshagri/30min
CALL_CREDIT_REWARD=100
